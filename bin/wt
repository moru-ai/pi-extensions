#!/usr/bin/env bash
set -euo pipefail

# ─── Config (override via env) ───────────────────────────────
WT_REMOTE_HOST="${WT_REMOTE_HOST:-}"
WT_REMOTE_USER="${WT_REMOTE_USER:-$(whoami)}"
WT_LOCAL_BASE="${WT_LOCAL_BASE:-/private/tmp}"

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; DIM='\033[2m'; NC='\033[0m'

log()  { echo -e "${GREEN}▸${NC} $*"; }
warn() { echo -e "${YELLOW}▸${NC} $*"; }
err()  { echo -e "${RED}✗${NC} $*" >&2; }
dim()  { echo -e "${DIM}  $*${NC}"; }

# ─── Helpers ─────────────────────────────────────────────────

repo_name() {
  local url
  url=$(git remote get-url origin 2>/dev/null || echo "")
  if [[ -n "$url" ]]; then
    basename "$url" .git
  else
    basename "$(git rev-parse --show-toplevel)"
  fi
}

repo_root() { git rev-parse --show-toplevel; }

local_wt_path()  { echo "${WT_LOCAL_BASE}/wt-${1}"; }
remote_wt_base() { echo "/Users/${WT_REMOTE_USER}/${1}-wt"; }
remote_wt_path() { echo "$(remote_wt_base "$1")/${2}"; }
remote_repo()    { echo "/Users/${WT_REMOTE_USER}/${1}"; }

require_remote() {
  if [[ -z "$WT_REMOTE_HOST" ]]; then
    err "WT_REMOTE_HOST not set. Configure it to use sync commands."
    err "  export WT_REMOTE_HOST=your-remote-host"
    err "  export WT_REMOTE_USER=your-remote-user"
    exit 1
  fi
}

# ─── create ──────────────────────────────────────────────────
cmd_create() {
  local name="" base="main" custom_branch=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --branch|-b) custom_branch="$2"; shift 2 ;;
      --base)      base="$2"; shift 2 ;;
      -*)          err "Unknown flag: $1"; exit 1 ;;
      *)
        if [[ -z "$name" ]]; then name="$1"; else base="$1"; fi
        shift ;;
    esac
  done

  if [[ -z "$name" ]]; then
    err "Usage: wt create <name> [base-branch]"
    err "       wt create <name> --branch <existing-branch>"
    exit 1
  fi

  local repo; repo=$(repo_name)
  local root; root=$(repo_root)
  local branch="${custom_branch:-plan/${name}}"
  local wt; wt=$(local_wt_path "$name")

  echo ""
  log "Creating worktree ${BLUE}${name}${NC}"
  dim "repo:   $repo"
  dim "branch: $branch"
  dim "path:   $wt"
  dim "base:   $base"
  echo ""

  if [[ -d "$wt" ]]; then
    warn "Already exists: $wt"
    log "cd $wt"
    exit 0
  fi

  if git show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
    log "Branch exists, checking out..."
    git worktree add "$wt" "$branch"
  elif [[ -n "$custom_branch" ]] && git show-ref --verify --quiet "refs/remotes/origin/$branch" 2>/dev/null; then
    log "Tracking remote branch..."
    git worktree add "$wt" --track -b "$branch" "origin/$branch"
  else
    log "Creating new branch from $base..."
    git worktree add -b "$branch" "$wt" "$base"
  fi

  if [[ -f "${root}/.env.local" ]]; then
    ln -sf "${root}/.env.local" "${wt}/.env.local"
    log "Linked .env.local"
  fi

  if [[ -d "${root}/node_modules" ]]; then
    cp -al "${root}/node_modules" "${wt}/node_modules"
    log "Hard-linked node_modules"
  fi

  mkdir -p "${wt}/docs/exec-plans/active"
  mkdir -p "${wt}/docs/exec-plans/artifacts"

  echo ""
  echo -e "${GREEN}✓ Ready${NC}"
  echo ""
  echo "  cd $wt"
  echo "  # Write plan → docs/exec-plans/active/<name>.md"
  echo "  # Then: wt send $name"
  echo ""
}

# ─── send (requires remote) ──────────────────────────────────
cmd_send() {
  require_remote
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    err "Usage: wt send <name>"
    exit 1
  fi

  local repo; repo=$(repo_name)
  local wt; wt=$(local_wt_path "$name")
  local branch

  if [[ -d "$wt" ]]; then
    branch=$(git -C "$wt" branch --show-current)
  else
    branch="plan/${name}"
  fi

  local rrepo; rrepo=$(remote_repo "$repo")
  local rwt; rwt=$(remote_wt_path "$repo" "$name")

  echo ""
  log "Sending ${BLUE}${name}${NC} → ${WT_REMOTE_HOST}"
  dim "branch: $branch"
  dim "remote: $rwt"
  echo ""

  log "Pushing branch..."
  git push origin "$branch" 2>&1 | tail -3 || git push -u origin "$branch" 2>&1 | tail -3

  log "Setting up on ${WT_REMOTE_HOST}..."
  ssh "$WT_REMOTE_HOST" bash -s -- "$rrepo" "$rwt" "$branch" <<'REMOTE'
    set -euo pipefail
    REPO="$1"; WT="$2"; BRANCH="$3"

    echo "  ▸ Fetching..."
    cd "$REPO"
    git fetch origin "$BRANCH" --quiet 2>/dev/null || git fetch origin --quiet

    mkdir -p "$(dirname "$WT")"
    if [[ -d "$WT" ]]; then
      echo "  ▸ Worktree exists, updating..."
      cd "$WT"
      git checkout "$BRANCH" 2>/dev/null || true
      git reset --hard "origin/$BRANCH" --quiet 2>/dev/null || git pull --ff-only
    else
      echo "  ▸ Creating worktree..."
      git worktree add "$WT" "$BRANCH" 2>/dev/null || \
        git worktree add "$WT" "origin/$BRANCH" --detach && git -C "$WT" checkout -B "$BRANCH" "origin/$BRANCH"
    fi

    if [[ ! -L "$WT/.env.local" ]] && [[ -f "$REPO/.env.local" ]]; then
      rm -f "$WT/.env.local"
      ln -sf "$REPO/.env.local" "$WT/.env.local"
      echo "  ▸ Linked .env.local"
    fi

    if [[ ! -d "$WT/node_modules" ]] && [[ -d "$REPO/node_modules" ]]; then
      rm -rf "$WT/node_modules"
      cp -al "$REPO/node_modules" "$WT/node_modules"
      echo "  ▸ Hard-linked node_modules"
    fi

    if [[ -f "$WT/prisma/schema.prisma" ]]; then
      echo "  ▸ Prisma generate..."
      cd "$WT"
      npx prisma generate --quiet 2>/dev/null || npx prisma generate
    fi

    echo ""
    echo "  ✓ Ready: $WT"
    echo "    Branch: $BRANCH"
REMOTE

  echo ""
  echo -e "${GREEN}✓ Sent${NC}"
  echo ""
  echo "  ssh $WT_REMOTE_HOST"
  echo "  cd $rwt"
  echo "  pi  # → /start-exec-plan-loop"
  echo ""
}

# ─── sync (requires remote) ──────────────────────────────────
cmd_sync() {
  require_remote
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    err "Usage: wt sync <name>"
    exit 1
  fi

  local repo; repo=$(repo_name)
  local wt; wt=$(local_wt_path "$name")
  local branch

  if [[ -d "$wt" ]]; then
    branch=$(git -C "$wt" branch --show-current)
  else
    branch="plan/${name}"
  fi

  local rwt; rwt=$(remote_wt_path "$repo" "$name")

  log "Syncing ${BLUE}${name}${NC}..."

  git push origin "$branch" --quiet 2>/dev/null

  ssh "$WT_REMOTE_HOST" bash -s -- "$rwt" "$branch" <<'REMOTE'
    set -euo pipefail
    cd "$1"
    git fetch origin "$2" --quiet
    git reset --hard "origin/$2" --quiet
    echo "  ✓ Synced to $(git rev-parse --short HEAD)"
REMOTE
}

# ─── list ────────────────────────────────────────────────────
cmd_list() {
  local repo; repo=$(repo_name)

  echo -e "${BLUE}Local${NC}"
  git worktree list | while IFS= read -r line; do
    echo "  $line"
  done

  if [[ -n "$WT_REMOTE_HOST" ]]; then
    echo ""
    echo -e "${BLUE}${WT_REMOTE_HOST} (${repo}-wt/)${NC}"
    local rwt_base; rwt_base=$(remote_wt_base "$repo")
    local rrepo; rrepo=$(remote_repo "$repo")

    ssh "$WT_REMOTE_HOST" bash -s -- "$rwt_base" "$rrepo" "$repo" <<'REMOTE'
      set -euo pipefail
      WT_BASE="$1"; REPO="$2"; REPO_NAME="$3"

      if [[ -d "$WT_BASE" ]] && ls "$WT_BASE"/*/ >/dev/null 2>&1; then
        for d in "$WT_BASE"/*/; do
          [[ -d "$d" ]] || continue
          name=$(basename "$d")
          branch=$(git -C "$d" branch --show-current 2>/dev/null || echo "?")
          sha=$(git -C "$d" rev-parse --short HEAD 2>/dev/null || echo "?")
          echo "  $name → $branch ($sha)"
        done
      else
        echo "  (none)"
      fi

      legacy=()
      for d in ~/"${REPO_NAME}"-*/; do
        [[ -d "$d" ]] || continue
        [[ "$d" == *"-wt"* ]] && continue
        [[ "$d" == *"-worktrees"* ]] && continue
        legacy+=("$d")
      done
      for d in ~/"${REPO_NAME}"-worktrees/*/; do
        [[ -d "$d" ]] || continue
        legacy+=("$d")
      done
      for d in ~/worktrees/*/; do
        [[ -d "$d" ]] || continue
        legacy+=("$d")
      done

      if [[ ${#legacy[@]} -gt 0 ]]; then
        echo ""
        echo "  Legacy (not managed):"
        for d in "${legacy[@]}"; do
          name=$(basename "$d")
          branch=$(git -C "$d" branch --show-current 2>/dev/null || echo "?")
          echo "    $d → $branch"
        done
      fi
REMOTE
  else
    echo ""
    dim "Remote: not configured (set WT_REMOTE_HOST to enable)"
  fi
}

# ─── clean ───────────────────────────────────────────────────
cmd_clean() {
  local name="${1:-}"
  local target="${2:-both}"

  if [[ -z "$name" ]]; then
    err "Usage: wt clean <name> [local|remote|both]"
    exit 1
  fi

  local repo; repo=$(repo_name)
  local wt; wt=$(local_wt_path "$name")

  if [[ "$target" == "local" || "$target" == "both" ]]; then
    if [[ -d "$wt" ]]; then
      log "Removing local: $wt"
      git worktree remove "$wt" --force 2>/dev/null || rm -rf "$wt"
      git worktree prune
    else
      dim "Local not found: $wt"
    fi
  fi

  if [[ "$target" == "remote" || "$target" == "both" ]]; then
    if [[ -n "$WT_REMOTE_HOST" ]]; then
      local rwt; rwt=$(remote_wt_path "$repo" "$name")
      local rrepo; rrepo=$(remote_repo "$repo")
      log "Removing ${WT_REMOTE_HOST}: $rwt"
      ssh "$WT_REMOTE_HOST" bash -s -- "$rrepo" "$rwt" <<'REMOTE'
        set -euo pipefail
        REPO="$1"; WT="$2"
        if [[ -d "$WT" ]]; then
          cd "$REPO"
          git worktree remove "$WT" --force 2>/dev/null || rm -rf "$WT"
          git worktree prune
          echo "  ✓ Removed"
        else
          echo "  Not found: $WT"
        fi
REMOTE
    else
      dim "Remote: not configured (set WT_REMOTE_HOST to skip)"
    fi
  fi

  log "${GREEN}✓ Cleaned${NC}"
}

# ─── main ────────────────────────────────────────────────────
case "${1:-help}" in
  create) shift; cmd_create "$@" ;;
  send)   shift; cmd_send "$@" ;;
  sync)   shift; cmd_sync "$@" ;;
  list)   cmd_list ;;
  ls)     cmd_list ;;
  clean)  shift; cmd_clean "$@" ;;
  rm)     shift; cmd_clean "$@" ;;
  help|-h|--help)
    cat <<EOF
wt — Worktree management with optional remote sync

Usage:
  wt create <name> [base]         Create local worktree + plan/<name> branch
  wt create <name> -b <branch>    Use existing/custom branch name
  wt send <name>                  Push + setup worktree on remote
  wt sync <name>                  Quick push + pull (no setup)
  wt list                         Show all worktrees
  wt clean <name> [local|remote|both]

Naming:
  Local:     ${WT_LOCAL_BASE:-/private/tmp}/wt-<name>/
  Remote:    ~/<repo>-wt/<name>/
  Branch:    plan/<name>  (default)

Environment:
  WT_REMOTE_HOST    Remote host for send/sync (e.g. mac-mini)
  WT_REMOTE_USER    Remote user (default: \$(whoami))
  WT_LOCAL_BASE     Local worktree base dir (default: /private/tmp)

Workflow:
  wt create agent-chat            # 1. Create local worktree
  cd ${WT_LOCAL_BASE:-/private/tmp}/wt-agent-chat
  # Write plan, code, test
  git add -A && git commit -m "plan: agent-chat"
  wt send agent-chat              # 2. Push + setup on remote
EOF
    ;;
  *)
    err "Unknown command: $1"
    err "Run 'wt help' for usage"
    exit 1
    ;;
esac
